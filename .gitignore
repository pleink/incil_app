#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android release signing — keystore + key.properties live at android/
# (gitignored; CI writes them from secrets, locally they're a manual copy)
/android/key.properties
/android/upload-keystore.p12
/android/*.p12
/android/*.jks
/android/*.keystore

# iOS / Xcode
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/flutter_export_environment.sh

# FVM Version Cache
.fvm/
.fvm/flutter_sdk

# Claude Code local state + mobile-dev plan scratch
.claude/settings.local.json
.claude/scheduled_tasks.lock
.mobile-dev/
